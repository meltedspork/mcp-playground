# =========================================
# Stage: Development (Vite React.js App)
# https://www.docker.com/blog/how-to-dockerize-react-app/
# =========================================
ARG NODE_VERSION=20-alpine
 
FROM node:${NODE_VERSION} AS dev
 
# Set working directory inside the container
WORKDIR /app
 
# Copy package files
COPY package*.json ./
 
# Install dependencies (use `npm ci` for reproducible installs in dev)
RUN npm ci
 
# Copy rest of the source code
COPY . .
 
 
# Ensure the "node" user owns the application files
# Note: when you bind-mount the project from the host, this `chown` plus
# `USER node` can cause permission issues because the host ownership differs.
# For local dev you can either run the container as root (set `user: root`
# in `compose.yml`) or remove the `chown`/`USER` here. Keep `USER node` for
# better security in CI and production images.
RUN chown -R node:node /app

# Switch to the built-in non-root "node" user (optional for local dev)
USER node
 
 
# Expose Vite dev server port
EXPOSE 5173
 
# Run Vite in dev mode, accessible outside the container
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]